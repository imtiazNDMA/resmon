# Canonical env contract (plan 01 §6.2). Copy to .env and fill real values.
# .env is git-ignored; never commit secrets. Secrets are file-mounted where possible.

# --- App / observability ---
APP_ENV=dev                          # dev | prod
LOG_LEVEL=INFO
LOG_FORMAT=json
DATA_STALENESS_THRESHOLD_DAYS=14     # NFR-REL-6 staleness flag (D8)

# --- Database (Postgres + PostGIS) ---
POSTGRES_DB=reservoir
POSTGRES_SUPERUSER=postgres
POSTGRES_SUPERPASSWORD=postgres
# Host port publish is dev-only (compose dev override); avoids clashes with a local Postgres.
POSTGRES_HOST_PORT=5432
# Role passwords consumed by infra/docker/postgres/init/01-init.sh on first boot.
# The compose dev override defaults these for dev; prod MUST set real values here
# (and keep the DATABASE_URL_* / service store URIs below in sync).
APP_RW_PASSWORD=app_rw
APP_RO_PASSWORD=app_ro
MLFLOW_DB_PASSWORD=mlflow
PREFECT_DB_PASSWORD=prefect
# App connection URLs (password part must match APP_*_PASSWORD above).
DATABASE_URL_RW=postgresql+psycopg://app_rw:app_rw@postgres:5432/reservoir
DATABASE_URL_RO=postgresql+psycopg://app_ro:app_ro@postgres:5432/reservoir
# For host-run tooling (e.g. alembic outside containers) use localhost:
# DATABASE_URL_RW=postgresql+psycopg://app_rw:app_rw@localhost:5432/reservoir

# --- MLflow ---
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_ARTIFACT_ROOT=/artifacts
# MLflow has its own database (D11); password must match MLFLOW_DB_PASSWORD.
MLFLOW_BACKEND_STORE_URI=postgresql+psycopg2://mlflow:mlflow@postgres:5432/mlflow_db

# --- Prefect ---
PREFECT_API_URL=http://prefect-server:4200/api
# Prefect has its own database (D11); password must match PREFECT_DB_PASSWORD.
PREFECT_API_DATABASE_CONNECTION_URL=postgresql+asyncpg://prefect:prefect@postgres:5432/prefect_db

# --- API serving ---
# Path prefix the reverse proxy strips before the app sees requests (Caddy handle_path
# /api/*). Set empty for bare local `uvicorn` if you want /docs to work without a proxy.
API_ROOT_PATH=/api

# --- Data access (the swappable GEE seam, §4.4) ---
DATA_ACCESS_BACKEND=gee              # gee | fixture | (future: openeo, planetary)
GEE_PROJECT=your-ee-project
GEE_SA_KEY_FILE=/run/secrets/gee_sa.json   # file-mounted; the repo's geeservice.json is git-ignored
