# Dev reverse proxy (plan 01 T-09). Caddy terminates TLS in prod; dev runs plain :80.
# Routes: /api -> api, /mlflow -> mlflow, /prefect -> prefect-server, / -> web.
{
	auto_https off
}

:80 {
	handle_path /api/* {
		reverse_proxy api:8000
	}
	handle_path /mlflow/* {
		reverse_proxy mlflow:5000
	}
	handle_path /prefect/* {
		reverse_proxy prefect-server:4200
	}
	handle {
		reverse_proxy web:80
	}
}
